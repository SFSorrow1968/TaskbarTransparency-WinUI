<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource OxygenShellBrush}">
        <Grid Padding="28,22,28,28" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="4">
                <TextBlock FontSize="30" FontWeight="SemiBold" Foreground="White" Text="Settings" />
                <TextBlock FontSize="16" Foreground="{StaticResource OxygenMutedTextBrush}" Text="App behavior, startup, and shortcuts. Appearance lives on the Dashboard." />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource OxygenCardBorderStyle}">
                <StackPanel Spacing="16">
                    <TextBlock FontSize="21" FontWeight="SemiBold" Foreground="White" Text="General" />
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="White" FontSize="16" Text="Show tray icon" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Closing the window keeps Oxygen Taskbar running in the tray." />
                        </StackPanel>
                        <ToggleSwitch x:Name="TraySwitch" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="TraySwitch_Toggled" />
                    </Grid>
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="White" FontSize="16" Text="Start with Windows" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Automatically start Oxygen Taskbar when you sign in." />
                        </StackPanel>
                        <ToggleSwitch x:Name="StartupSwitch" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="StartupSwitch_Toggled" />
                    </Grid>
                    <InfoBar x:Name="StartupPermissionInfo" IsOpen="False" IsClosable="False" Severity="Warning" Title="Startup registration">
                        <InfoBar.ActionButton>
                            <Button Click="RetryStartup_Click" Content="Retry" />
                        </InfoBar.ActionButton>
                    </InfoBar>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource OxygenCardBorderStyle}">
                <StackPanel Spacing="16">
                    <TextBlock FontSize="21" FontWeight="SemiBold" Foreground="White" Text="Keyboard shortcuts" />
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Foreground="White" FontSize="16" Text="Open Oxygen Taskbar" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Show or focus this window." />
                        </StackPanel>
                        <TextBox x:Name="OpenHotkeyText" Grid.Column="1" PlaceholderText="Ctrl+Alt+G" />
                    </Grid>
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Foreground="White" FontSize="16" Text="Pause or resume transparency" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Temporarily restore the normal taskbar look." />
                        </StackPanel>
                        <TextBox x:Name="ToggleHotkeyText" Grid.Column="1" PlaceholderText="Ctrl+Alt+T" />
                    </Grid>
                    <InfoBar x:Name="HotkeyRegistrationInfo" IsOpen="True" IsClosable="False" Title="Shortcut registration" />
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Use modifier + key, for example Ctrl+Alt+T." VerticalAlignment="Center" />
                        <Button Grid.Column="1" Click="ResetHotkeys_Click" Style="{StaticResource GlassButtonStyle}" Content="Reset to defaults" />
                        <Button Grid.Column="2" Click="SaveHotkeys_Click" Style="{StaticResource GlassButtonStyle}" Background="{StaticResource OxygenBlueBrush}" Content="Save shortcuts" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
