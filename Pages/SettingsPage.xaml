<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TaskbarTransparency.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="32,24,32,32" Spacing="18">
        <StackPanel Spacing="6">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Keep the app quiet, recoverable, and predictable." />
        </StackPanel>
        <ToggleSwitch x:Name="TraySwitch" Header="Show system tray icon" Toggled="TraySwitch_Toggled" />
        <TextBox x:Name="OpenHotkeyText" Header="Open dashboard hotkey" IsReadOnly="True" />
        <TextBox x:Name="ToggleHotkeyText" Header="Toggle transparency hotkey" IsReadOnly="True" />
        <InfoBar IsOpen="True" Severity="Informational" Title="Hotkeys" Message="Global hotkey registration is queued for the next implementation pass; defaults are preserved in settings now." />
    </StackPanel>
</Page>
