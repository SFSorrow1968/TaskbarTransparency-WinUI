<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="{StaticResource OxygenShellBrush}">
        <Grid Padding="44,34,44,44" RowSpacing="18" MaxWidth="1100" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource OxygenPageTitleTextBlockStyle}" Text="Diagnostics" />
                <TextBlock FontSize="18" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Detection status, recent activity, and recovery actions." />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource OxygenCardBorderStyle}">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="StatusIconBorder" Width="58" Height="58" Background="#3323C58E" CornerRadius="29" VerticalAlignment="Center">
                        <FontIcon x:Name="StatusIcon" Foreground="{StaticResource OxygenMintBrush}" FontSize="28" Glyph="&#xE930;" />
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusTitleText" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="Taskbar detected" />
                        <TextBlock x:Name="StatusDetailText" Foreground="{StaticResource OxygenMutedTextBrush}" TextWrapping="Wrap" />
                        <TextBlock x:Name="StatusHintText" Foreground="{StaticResource OxygenMutedTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="2" Click="Reapply_Click" Style="{StaticResource GlassButtonStyle}" Background="{StaticResource OxygenBlueBrush}" Content="Retry and reapply" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource OxygenCardBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="White" Text="Recent activity" />
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="The last few opacity changes from this session." />
                        <ListView x:Name="ActivityList" MaxHeight="320" SelectionMode="None" Background="Transparent">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="MinHeight" Value="52" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12,10" Background="#58233448" CornerRadius="8">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="96" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="64" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="{Binding TimeText}" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding State}" />
                                                <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Foreground="{StaticResource OxygenBlueBrush}" FontWeight="SemiBold" Text="{Binding OpacityText}" TextAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Style="{StaticResource OxygenCardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="White" Text="Shortcuts" />
                            <InfoBar x:Name="HotkeyInfo" IsOpen="True" IsClosable="False" Title="Registration" />
                            <Button Click="ResetHotkeys_Click" Style="{StaticResource GlassButtonStyle}" Content="Reset shortcuts to defaults" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource OxygenCardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="White" Text="Logs" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Launcher build and run logs." TextWrapping="Wrap" />
                            <Button Click="OpenLogFolder_Click" Style="{StaticResource GlassButtonStyle}" Content="Open log folder" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
