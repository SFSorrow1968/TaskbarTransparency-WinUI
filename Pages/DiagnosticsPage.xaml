<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Padding="32,24,32,32" Spacing="18">
        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Diagnostics" />
        <Border Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
            <StackPanel Spacing="10">
                <TextBlock x:Name="MessageText" FontSize="18" FontWeight="SemiBold" />
                <TextBlock x:Name="DetailsText" TextWrapping="Wrap" />
                <Button Click="ApplyDesktop_Click" Content="Reapply desktop state" />
                <Button Click="ApplyHover_Click" Content="Simulate hover reveal" />
                <Button Click="ApplyFullscreen_Click" Content="Simulate fullscreen state" />
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
