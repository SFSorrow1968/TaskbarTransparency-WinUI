<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.MonitorsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="{StaticResource OxygenShellBrush}">
        <Grid Padding="44,34,44,44" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="6">
                <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Foreground="{StaticResource OxygenBlueBrush}" Text="MONITORS" />
                <TextBlock Style="{StaticResource OxygenPageTitleTextBlockStyle}" Text="Display 2" />
                <TextBlock FontSize="18" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Configure taskbar appearance and behavior for this display only." />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource OxygenCardBorderStyle}">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="MonitorNameText" FontSize="26" FontWeight="SemiBold" Foreground="White" Text="Primary display" />
                        <TextBlock x:Name="MonitorDeviceText" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Shell_TrayWnd" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Padding="12,8" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                <TextBlock Foreground="White" Text="Display 2" />
                            </Border>
                            <Border Padding="12,8" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                <TextBlock Foreground="White" Text="2560 x 1440" />
                            </Border>
                            <Border Padding="12,8" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                <TextBlock Foreground="White" Text="60 Hz" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="12">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="White" Text="Sync with primary settings" />
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="When on, this display follows your primary display settings." TextWrapping="Wrap" />
                        <ToggleSwitch x:Name="SyncSwitch" Header="Sync" IsOn="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource OxygenCardBorderStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="21" FontWeight="SemiBold" Foreground="White" Text="Appearance override" />
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Adjust taskbar appearance for this display." />
                        <TextBlock Foreground="White" Text="Taskbar opacity" />
                        <Slider x:Name="OverrideOpacitySlider" Maximum="100" Minimum="0" Value="64" ValueChanged="OverrideOpacitySlider_ValueChanged" />
                        <TextBlock x:Name="OverrideOpacityText" Foreground="White" FontSize="22" FontWeight="SemiBold" Text="64%" />
                        <ComboBox Header="Material" SelectedIndex="0" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Mica (Acrylic)" />
                            <ComboBoxItem Content="Clear" />
                            <ComboBoxItem Content="Solid" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource OxygenCardBorderStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="21" FontWeight="SemiBold" Foreground="White" Text="Status" />
                        <Border Padding="16" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Foreground="{StaticResource OxygenMintBrush}" Glyph="&#xE73E;" />
                                <TextBlock Grid.Column="1" Foreground="White" Text="Taskbar detected" />
                                <TextBlock x:Name="DetectedText" Grid.Column="2" Foreground="{StaticResource OxygenMintBrush}" Text="Detected" />
                            </Grid>
                        </Border>
                        <TextBlock x:Name="BoundToText" Foreground="{StaticResource OxygenMutedTextBrush}" TextWrapping="Wrap" />
                        <TextBlock x:Name="TaskbarWindowText" Foreground="{StaticResource OxygenMutedTextBrush}" />
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Last seen: Just now" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>
                <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="This override affects the selected display only." VerticalAlignment="Center" />
                <Button Grid.Column="1" Click="Refresh_Click" Style="{StaticResource GlassButtonStyle}" Content="Revert" />
                <Button Grid.Column="2" Click="ApplyOverride_Click" Style="{StaticResource GlassButtonStyle}" Background="{StaticResource OxygenBlueBrush}" Content="Apply" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
