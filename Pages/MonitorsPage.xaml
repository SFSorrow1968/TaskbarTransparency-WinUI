<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.MonitorsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TaskbarTransparency.Pages">

    <ScrollViewer Background="{StaticResource OxygenShellBrush}">
        <Grid Padding="44,34,44,44" RowSpacing="18" MaxWidth="1100" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource OxygenPageTitleTextBlockStyle}" Text="Monitors" />
                    <TextBlock x:Name="SummaryText" FontSize="18" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Each display follows the base opacity unless you give it its own value." TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Click="Detect_Click" Style="{StaticResource GlassButtonStyle}" Content="Detect displays" VerticalAlignment="Top" />
            </Grid>

            <InfoBar x:Name="NoDisplayInfo" Grid.Row="1" IsOpen="False" IsClosable="False" Severity="Warning" Title="No taskbar detected" Message="No taskbar window is currently available. If Windows Explorer is restarting, use Detect displays to retry." />

            <ItemsControl x:Name="MonitorList" Grid.Row="2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:MonitorRow">
                        <Border Margin="0,0,0,14" Style="{StaticResource OxygenCardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="White" Text="{x:Bind Name}" />
                                            <Border Padding="10,4" Background="#332878FF" CornerRadius="10" Visibility="{x:Bind PrimaryBadgeVisibility}">
                                                <TextBlock FontSize="13" Foreground="White" Text="Primary" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="{x:Bind Device}" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" Header="Follow base opacity" IsOn="{x:Bind SyncWithPrimary, Mode=TwoWay}" OffContent="Off" OnContent="On" Toggled="SyncSwitch_Toggled" />
                                </Grid>
                                <Grid ColumnSpacing="18" Visibility="{x:Bind OverrideVisibility, Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Opacity for this display" VerticalAlignment="Center" />
                                    <Slider Grid.Column="1" Maximum="100" Minimum="0" StepFrequency="1" Value="{x:Bind Opacity, Mode=TwoWay}" ValueChanged="OverrideSlider_ValueChanged" />
                                    <TextBlock Grid.Column="2" FontSize="20" FontWeight="SemiBold" Foreground="White" Text="{x:Bind OpacityText, Mode=OneWay}" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</Page>
