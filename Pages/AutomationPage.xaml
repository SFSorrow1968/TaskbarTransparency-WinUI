<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.AutomationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="{StaticResource OxygenShellBrush}">
        <Grid Padding="44,34,44,44" RowSpacing="18" MaxWidth="1100" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource OxygenPageTitleTextBlockStyle}" Text="Rules" />
                    <TextBlock FontSize="18" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Each rule sets the exact taskbar opacity for a state. The first matching rule from the top wins; otherwise the base opacity applies." TextWrapping="Wrap" />
                </StackPanel>
                <ToggleSwitch x:Name="AutomationSwitch" Grid.Column="1" Header="Automation" OffContent="Off" OnContent="On" Toggled="AutomationSwitch_Toggled" VerticalAlignment="Top" />
            </Grid>

            <Border Grid.Row="1" Padding="18" Background="#3323C58E" CornerRadius="8">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Foreground="{StaticResource OxygenMintBrush}" Text="Right now" />
                        <TextBlock x:Name="NowStateText" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="Desktop" />
                        <TextBlock x:Name="NowDetailText" Foreground="{StaticResource OxygenMutedTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Applied" />
                        <TextBlock x:Name="NowOpacityText" FontSize="34" FontWeight="SemiBold" Foreground="{StaticResource OxygenBlueBrush}" HorizontalAlignment="Right" Text="30%" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Spacing="14">
                <Border Style="{StaticResource OxygenCardBorderStyle}">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="White" Text="1 · Hover" />
                                <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="When the pointer is near a taskbar." TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch x:Name="HoverSwitch" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="RuleSwitch_Toggled" Tag="Hover" />
                        </Grid>
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="HoverOpacitySlider" Maximum="100" Minimum="0" StepFrequency="1" Tag="Hover" ValueChanged="RuleSlider_ValueChanged" />
                            <TextBlock x:Name="HoverOpacityText" Grid.Column="1" FontSize="20" FontWeight="SemiBold" Foreground="White" Text="100%" VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Hover distance" VerticalAlignment="Center" />
                            <Slider x:Name="HoverDistanceSlider" Grid.Column="1" Maximum="48" Minimum="0" StepFrequency="1" ValueChanged="HoverDistanceSlider_ValueChanged" />
                            <TextBlock x:Name="HoverDistanceText" Grid.Column="2" FontSize="20" FontWeight="SemiBold" Foreground="White" Text="8 px" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource OxygenCardBorderStyle}">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="White" Text="2 · Fullscreen" />
                                <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="When the active window covers the whole screen." TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch x:Name="FullscreenSwitch" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="RuleSwitch_Toggled" Tag="Fullscreen" />
                        </Grid>
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="FullscreenOpacitySlider" Maximum="100" Minimum="0" StepFrequency="1" Tag="Fullscreen" ValueChanged="RuleSlider_ValueChanged" />
                            <TextBlock x:Name="FullscreenOpacityText" Grid.Column="1" FontSize="20" FontWeight="SemiBold" Foreground="White" Text="100%" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource OxygenCardBorderStyle}">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="White" Text="3 · Maximized window" />
                                <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="When the active window is maximized." TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch x:Name="MaximizedSwitch" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="RuleSwitch_Toggled" Tag="WindowMaximized" />
                        </Grid>
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="MaximizedOpacitySlider" Maximum="100" Minimum="0" StepFrequency="1" Tag="WindowMaximized" ValueChanged="RuleSlider_ValueChanged" />
                            <TextBlock x:Name="MaximizedOpacityText" Grid.Column="1" FontSize="20" FontWeight="SemiBold" Foreground="White" Text="60%" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource OxygenCardBorderStyle}">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="White" Text="4 · Open window" />
                                <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="When any window is in the foreground (not maximized)." TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch x:Name="WindowSwitch" Grid.Column="1" OffContent="Off" OnContent="On" Toggled="RuleSwitch_Toggled" Tag="WindowVisible" />
                        </Grid>
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="WindowOpacitySlider" Maximum="100" Minimum="0" StepFrequency="1" Tag="WindowVisible" ValueChanged="RuleSlider_ValueChanged" />
                            <TextBlock x:Name="WindowOpacityText" Grid.Column="1" FontSize="20" FontWeight="SemiBold" Foreground="White" Text="45%" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
