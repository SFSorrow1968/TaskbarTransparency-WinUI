<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TaskbarTransparency.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource OxygenShellBrush}">
        <Grid Padding="44,34,44,44" RowSpacing="18" MaxWidth="1100" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="6">
                <TextBlock FontSize="36" FontWeight="SemiBold" Foreground="White" Text="Dashboard" />
                <TextBlock FontSize="18" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Your taskbar right now, and the one number that controls it." />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource OxygenCardBorderStyle}" Padding="28">
                <Grid ColumnSpacing="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="230" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Applied opacity" />
                        <TextBlock x:Name="AppliedOpacityText" FontSize="58" FontWeight="SemiBold" Foreground="White" Text="30%" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <TextBlock x:Name="AppliedSourceText" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="Base opacity" />
                        <TextBlock x:Name="AppliedStateText" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Current state: Desktop" />
                        <TextBlock x:Name="AppliedDetailText" Foreground="{StaticResource OxygenMutedTextBrush}" TextWrapping="Wrap" Text="Applied to 1 taskbar" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="10">
                        <Button x:Name="PauseButton" Click="Pause_Click" Style="{StaticResource GlassButtonStyle}" Content="Pause transparency" />
                        <Button Click="Reapply_Click" Style="{StaticResource GlassButtonStyle}" Content="Reapply now" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource OxygenCardBorderStyle}" Padding="24">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock FontSize="21" FontWeight="SemiBold" Foreground="White" Text="Base opacity" />
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Used on the desktop and whenever no rule overrides it. 0% is fully transparent, 100% is solid." TextWrapping="Wrap" />
                    </StackPanel>
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="96" />
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="OpacitySlider" Maximum="100" Minimum="0" StepFrequency="1" ValueChanged="OpacitySlider_ValueChanged" VerticalAlignment="Center" />
                        <Border Grid.Column="1" Padding="10" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                            <TextBlock x:Name="OpacityValueBoxText" HorizontalAlignment="Center" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="30%" />
                        </Border>
                    </Grid>
                    <InfoBar x:Name="OverrideInfo" IsOpen="False" IsClosable="False" Severity="Informational" Title="A rule is overriding this value right now" Message="The applied opacity above comes from a rule. Edit rules on the Rules page." />
                </StackPanel>
            </Border>

            <Grid Grid.Row="3" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource OxygenCardBorderStyle}" Padding="20">
                    <StackPanel Spacing="6">
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Automation" />
                        <ToggleSwitch x:Name="AutomationSwitch" OffContent="Off" OnContent="On" Toggled="AutomationSwitch_Toggled" />
                        <TextBlock x:Name="AutomationDetailText" Foreground="{StaticResource OxygenMutedTextBrush}" TextWrapping="Wrap" Text="Rules react to hover, fullscreen, and windows." />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource OxygenCardBorderStyle}" Padding="20">
                    <StackPanel Spacing="6">
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Taskbars" />
                        <TextBlock x:Name="TaskbarsText" Style="{StaticResource MetricTextBlockStyle}" Text="0" />
                        <TextBlock x:Name="TaskbarsDetailText" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Detected and controlled" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource OxygenCardBorderStyle}" Padding="20">
                    <StackPanel Spacing="6">
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Last applied" />
                        <TextBlock x:Name="LastAppliedText" Style="{StaticResource MetricTextBlockStyle}" Text="—" />
                        <TextBlock x:Name="LastMessageText" Foreground="{StaticResource OxygenMutedTextBrush}" TextWrapping="Wrap" Text="Ready" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
