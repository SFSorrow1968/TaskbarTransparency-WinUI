<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TaskbarTransparency.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource OxygenShellBrush}">
        <Grid Padding="44,34,44,44" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="6">
                <TextBlock FontSize="36" FontWeight="SemiBold" Foreground="White" Text="Dashboard" />
                <TextBlock FontSize="18" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Manage live taskbar material and opacity" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Padding="22" Background="{StaticResource OxygenCardBrush}" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8" MinHeight="124">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="76" Height="76" Background="#FFA8F2E5" CornerRadius="38">
                            <FontIcon FontSize="34" Foreground="#FF10283D" Glyph="&#xF0E2;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                            <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Profile" />
                            <TextBlock x:Name="ProfileText" Style="{StaticResource MetricTextBlockStyle}" Text="Oxygen Clear" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Active preset" />
                        </StackPanel>
                        <FontIcon Grid.Column="2" Foreground="{StaticResource OxygenMutedTextBrush}" Glyph="&#xE974;" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Border Grid.Column="1" Padding="22" Background="{StaticResource OxygenCardBrush}" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8" MinHeight="124">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="76" Height="76" Background="#FF8EC5FF" CornerRadius="38">
                            <FontIcon FontSize="34" Foreground="#FF10283D" Glyph="&#xE9CA;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                            <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Opacity" />
                            <TextBlock x:Name="OpacityText" Style="{StaticResource MetricTextBlockStyle}" Text="32%" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Live desktop state" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Padding="22" Background="{StaticResource OxygenCardBrush}" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8" MinHeight="124">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="76" Height="76" Background="#FFA8F2E5" CornerRadius="38">
                            <FontIcon FontSize="34" Foreground="#FF10283D" Glyph="&#xE7F4;" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                            <TextBlock Style="{StaticResource SectionHeaderTextBlockStyle}" Text="Taskbars" />
                            <TextBlock x:Name="TaskbarsText" Style="{StaticResource MetricTextBlockStyle}" Text="0" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Detected and controlled" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource OxygenCardBrush}" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                <Grid RowSpacing="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Padding="24,22,24,8" Spacing="14">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="21" FontWeight="SemiBold" Foreground="White" Text="Live opacity" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Adjust current taskbar opacity in real time." />
                        </StackPanel>
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="116" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="White" FontSize="18" Text="0%" VerticalAlignment="Center" />
                            <Slider x:Name="OpacitySlider" Grid.Column="1" Maximum="100" Minimum="0" StepFrequency="1" ValueChanged="OpacitySlider_ValueChanged" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Foreground="White" FontSize="18" Text="100%" VerticalAlignment="Center" />
                            <Border Grid.Column="3" Padding="10" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                                <TextBlock x:Name="OpacityValueBoxText" HorizontalAlignment="Center" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="32%" />
                            </Border>
                        </Grid>
                    </StackPanel>
                    <Grid Grid.Row="1" Padding="24,18,24,20" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="0,1,0,0" ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.1*" />
                        </Grid.ColumnDefinitions>
                        <Button Style="{StaticResource GlassButtonStyle}" Click="ApplyClear_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                <FontIcon Foreground="{StaticResource OxygenMutedTextBrush}" Glyph="&#xE734;" />
                                <TextBlock Text="Clear" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource GlassButtonStyle}" Click="ApplyGlass_Click" BorderBrush="#FF52D9DC">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                <FontIcon Foreground="#FF52D9DC" Glyph="&#xF0E2;" />
                                <TextBlock Text="Glass" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource GlassButtonStyle}" Click="ApplySolid_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                <FontIcon Foreground="{StaticResource OxygenMutedTextBrush}" Glyph="&#xE73B;" />
                                <TextBlock Text="Solid" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource GlassButtonStyle}" Click="ApplyNow_Click" Background="{StaticResource OxygenBlueBrush}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                                <FontIcon Foreground="White" Glyph="&#xE768;" />
                                <TextBlock Foreground="White" Text="Apply now" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3" Padding="24" Background="{StaticResource OxygenCardBrush}" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="21" FontWeight="SemiBold" Foreground="White" Text="Runtime status" />
                    <Grid Background="#58233448" CornerRadius="8" RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="52" />
                            <RowDefinition Height="52" />
                            <RowDefinition Height="52" />
                            <RowDefinition Height="52" />
                            <RowDefinition Height="52" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>

                        <FontIcon Margin="18,0,0,0" Foreground="#FF35AAFF" Glyph="&#xE713;" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Service" VerticalAlignment="Center" />
                        <Ellipse Grid.Column="2" Width="10" Height="10" Fill="#FF6EE28B" />
                        <TextBlock x:Name="ServiceStatusText" Grid.Column="3" Foreground="White" Text="Running" VerticalAlignment="Center" />
                        <FontIcon Grid.Column="4" Foreground="{StaticResource OxygenMutedTextBrush}" Glyph="&#xE974;" VerticalAlignment="Center" />

                        <FontIcon Grid.Row="1" Margin="18,0,0,0" Foreground="#FF52D9DC" Glyph="&#xF0E2;" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Current material" VerticalAlignment="Center" />
                        <Ellipse Grid.Row="1" Grid.Column="2" Width="10" Height="10" Fill="#FF35AAFF" />
                        <TextBlock x:Name="CurrentMaterialText" Grid.Row="1" Grid.Column="3" Foreground="White" Text="Clear" VerticalAlignment="Center" />
                        <FontIcon Grid.Row="1" Grid.Column="4" Foreground="{StaticResource OxygenMutedTextBrush}" Glyph="&#xE974;" VerticalAlignment="Center" />

                        <FontIcon Grid.Row="2" Margin="18,0,0,0" Foreground="#FF88B8FF" Glyph="&#xE916;" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Last applied" VerticalAlignment="Center" />
                        <Ellipse Grid.Row="2" Grid.Column="2" Width="10" Height="10" Fill="#FF88B8FF" />
                        <TextBlock x:Name="RuntimeTimeText" Grid.Row="2" Grid.Column="3" Foreground="White" Text="Today" VerticalAlignment="Center" />
                        <FontIcon Grid.Row="2" Grid.Column="4" Foreground="{StaticResource OxygenMutedTextBrush}" Glyph="&#xE974;" VerticalAlignment="Center" />

                        <FontIcon Grid.Row="3" Margin="18,0,0,0" Foreground="#FF52D9DC" Glyph="&#xE9CE;" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Session state" VerticalAlignment="Center" />
                        <Ellipse Grid.Row="3" Grid.Column="2" Width="10" Height="10" Fill="#FF6EE28B" />
                        <TextBlock x:Name="RuntimeMessageText" Grid.Row="3" Grid.Column="3" Foreground="White" Text="Watching desktop changes" TextWrapping="Wrap" VerticalAlignment="Center" />
                        <FontIcon Grid.Row="3" Grid.Column="4" Foreground="{StaticResource OxygenMutedTextBrush}" Glyph="&#xE974;" VerticalAlignment="Center" />

                        <FontIcon Grid.Row="4" Margin="18,0,0,0" Foreground="#FF6EE28B" Glyph="&#xE895;" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Sync state" VerticalAlignment="Center" />
                        <Ellipse Grid.Row="4" Grid.Column="2" Width="10" Height="10" Fill="#FF6EE28B" />
                        <TextBlock x:Name="SyncStateText" Grid.Row="4" Grid.Column="3" Foreground="White" Text="All taskbars in sync" VerticalAlignment="Center" />
                        <FontIcon Grid.Row="4" Grid.Column="4" Foreground="{StaticResource OxygenMutedTextBrush}" Glyph="&#xE974;" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
