<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TaskbarTransparency.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="32,24,32,32" Spacing="18">
        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="About" />
        <Border Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
            <StackPanel Spacing="10">
                <TextBlock FontSize="22" FontWeight="SemiBold" Text="Oxygen Taskbar" />
                <TextBlock TextWrapping="Wrap" Text="A from-scratch WinUI 3 rebuild of TaskbarTransparency focused on clear taskbar materials, simple automation, per-monitor control, and a calmer settings surface." />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Version 0.1.0" />
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
