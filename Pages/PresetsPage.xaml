<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.PresetsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="{StaticResource OxygenShellBrush}">
        <Grid Padding="44,34,44,44" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource OxygenPageTitleTextBlockStyle}" Text="Focus Glass" />
                    <TextBlock FontSize="18" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Customize how your taskbar looks and behaves." />
                </StackPanel>
                <Border HorizontalAlignment="Right" Padding="16,10" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Foreground="{StaticResource OxygenMutedTextBrush}" Glyph="&#xE8F1;" />
                        <TextBlock Foreground="White" Text="Synced displays" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource OxygenCardBorderStyle}">
                <StackPanel Spacing="18">
                    <TextBox x:Name="PresetNameText" Header="Preset name" Text="Focus Glass" />
                    <TextBlock FontSize="19" FontWeight="SemiBold" Foreground="White" Text="Material" />
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Click="Clear_Click" Style="{StaticResource GlassButtonStyle}" Content="Clear" />
                        <Button Grid.Column="1" Click="Glass_Click" Style="{StaticResource GlassButtonStyle}" BorderBrush="{StaticResource OxygenBlueBrush}" Content="Acrylic" />
                        <Button Grid.Column="2" Style="{StaticResource GlassButtonStyle}" Content="Mica" />
                        <Button Grid.Column="3" Click="Glass_Click" Style="{StaticResource GlassButtonStyle}" Background="#332878FF" Content="Glass" />
                    </Grid>
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="White" Text="Opacity" VerticalAlignment="Center" />
                        <Slider x:Name="PresetOpacitySlider" Grid.Column="1" Maximum="100" Minimum="0" ValueChanged="PresetOpacitySlider_ValueChanged" />
                        <TextBlock x:Name="PresetOpacityText" Grid.Column="2" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="72%" VerticalAlignment="Center" />
                    </Grid>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="White" Text="Tint / Accent" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="18">
                            <Ellipse Width="34" Height="34" Fill="{StaticResource OxygenBlueBrush}" Stroke="White" StrokeThickness="2" />
                            <Ellipse Width="34" Height="34" Fill="#FF52D9DC" />
                            <Ellipse Width="34" Height="34" Fill="#FF6EE28B" />
                            <Ellipse Width="34" Height="34" Fill="#FFA8F2E5" />
                            <Ellipse Width="34" Height="34" Fill="#FFFFB454" />
                            <Button Width="42" Height="42" Content="+" />
                        </StackPanel>
                    </Grid>
                    <ComboBox Header="Easing" SelectedIndex="0" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Smooth (220 ms)" />
                        <ComboBoxItem Content="CubicOut (180 ms)" />
                        <ComboBoxItem Content="Linear (120 ms)" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource OxygenCardBorderStyle}">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="21" FontWeight="SemiBold" Foreground="White" Text="Preview" />
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Height="72" BorderBrush="{StaticResource OxygenBlueBrush}" BorderThickness="1" CornerRadius="8">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Text="Default taskbar preview" />
                        </Border>
                        <Border Grid.Column="1" Height="72" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Text="Maximized window" />
                        </Border>
                        <Border Grid.Column="2" Height="72" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" Text="Start menu open" />
                        </Border>
                    </Grid>
                    <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Applies to synced displays." />
                </StackPanel>
            </Border>

            <Grid Grid.Row="3" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Use the preset cards or save this customized Focus Glass profile." VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{StaticResource GlassButtonStyle}" Click="Glass_Click" Content="Reset" />
                <Button Grid.Column="2" Style="{StaticResource GlassButtonStyle}" Background="{StaticResource OxygenBlueBrush}" Click="SaveFocusGlass_Click" Content="Save changes" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
