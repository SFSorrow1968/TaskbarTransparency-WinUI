<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TaskbarTransparency.Pages.PresetsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="{StaticResource OxygenShellBrush}">
        <Grid Padding="44,34,44,44" RowSpacing="18" MaxWidth="1440" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource OxygenPageTitleTextBlockStyle}" Text="Taskbar Tuning" />
                    <TextBlock FontSize="18" Foreground="{StaticResource OxygenMutedTextBrush}" Text="Adjust appearance, transitions, sensors, startup, tray, and shortcuts from one place." />
                </StackPanel>
                <Border HorizontalAlignment="Right" Padding="16,10" BorderBrush="{StaticResource OxygenCardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Foreground="{StaticResource OxygenMutedTextBrush}" Glyph="&#xE8F1;" />
                        <TextBlock Foreground="White" Text="Synced displays" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource OxygenCardBorderStyle}">
                <StackPanel Spacing="18">
                    <TextBox x:Name="PresetNameText" Header="Preset name" Text="Focus Glass" TextChanged="PresetNameText_TextChanged" />
                    <TextBlock FontSize="19" FontWeight="SemiBold" Foreground="White" Text="Material" />
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Click="Clear_Click" Style="{StaticResource GlassButtonStyle}" Content="Clear" />
                        <Button Grid.Column="1" Click="Acrylic_Click" Style="{StaticResource GlassButtonStyle}" BorderBrush="{StaticResource OxygenBlueBrush}" Content="Acrylic" />
                        <Button Grid.Column="2" Click="Mica_Click" Style="{StaticResource GlassButtonStyle}" Content="Mica" />
                        <Button Grid.Column="3" Click="Solid_Click" Style="{StaticResource GlassButtonStyle}" Background="#332878FF" Content="Solid" />
                    </Grid>
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="White" Text="Opacity" VerticalAlignment="Center" />
                        <Slider x:Name="PresetOpacitySlider" Grid.Column="1" Maximum="100" Minimum="0" ValueChanged="PresetOpacitySlider_ValueChanged" />
                        <TextBlock x:Name="PresetOpacityText" Grid.Column="2" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="72%" VerticalAlignment="Center" />
                    </Grid>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="White" Text="Tint / Accent" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="18">
                            <Ellipse Width="34" Height="34" Fill="{StaticResource OxygenBlueBrush}" Stroke="White" StrokeThickness="2" />
                            <Ellipse Width="34" Height="34" Fill="#FF52D9DC" />
                            <Ellipse Width="34" Height="34" Fill="#FF6EE28B" />
                            <Ellipse Width="34" Height="34" Fill="#FFA8F2E5" />
                            <Ellipse Width="34" Height="34" Fill="#FFFFB454" />
                            <Button Width="42" Height="42" Content="+" />
                        </StackPanel>
                    </Grid>
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="White" Text="Fade in" VerticalAlignment="Center" />
                        <Slider x:Name="FadeInDurationSlider" Grid.Column="1" Maximum="1000" Minimum="0" StepFrequency="10" ValueChanged="FadeInDurationSlider_ValueChanged" />
                        <TextBlock x:Name="FadeInDurationText" Grid.Column="2" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="220 ms" VerticalAlignment="Center" />
                    </Grid>
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="White" Text="Fade out" VerticalAlignment="Center" />
                        <Slider x:Name="FadeOutDurationSlider" Grid.Column="1" Maximum="1000" Minimum="0" StepFrequency="10" ValueChanged="FadeOutDurationSlider_ValueChanged" />
                        <TextBlock x:Name="FadeOutDurationText" Grid.Column="2" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="180 ms" VerticalAlignment="Center" />
                    </Grid>
                    <ComboBox x:Name="EasingComboBox" Header="Easing" SelectedIndex="0" SelectionChanged="EasingComboBox_SelectionChanged" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="Smooth cubic out" Tag="CubicOut" />
                        <ComboBoxItem Content="Quick quint out" Tag="QuintOut" />
                        <ComboBoxItem Content="Linear" Tag="Linear" />
                    </ComboBox>
                    <TextBlock FontSize="19" FontWeight="SemiBold" Foreground="White" Text="Sensor calibration" />
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="White" Text="Hover proximity" VerticalAlignment="Center" />
                        <Slider x:Name="HoverDistanceSlider" Grid.Column="1" Maximum="48" Minimum="0" StepFrequency="1" ValueChanged="HoverDistanceSlider_ValueChanged" />
                        <TextBlock x:Name="HoverDistanceText" Grid.Column="2" FontSize="22" FontWeight="SemiBold" Foreground="White" Text="8 px" VerticalAlignment="Center" />
                    </Grid>
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Runtime automation sensors" VerticalAlignment="Center" />
                        <ToggleSwitch x:Name="AutomationSwitch" Grid.Column="1" Header="Automation" Toggled="AutomationSwitch_Toggled" />
                        <ToggleSwitch x:Name="HoverSwitch" Grid.Column="2" Header="Hover" Toggled="HoverSwitch_Toggled" />
                        <ToggleSwitch x:Name="FullscreenSwitch" Grid.Column="3" Header="Fullscreen" Toggled="FullscreenSwitch_Toggled" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource OxygenCardBorderStyle}">
                <StackPanel Spacing="18">
                    <TextBlock FontSize="21" FontWeight="SemiBold" Foreground="White" Text="App settings" />
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="White" FontSize="18" Text="Show tray icon" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Keep the Oxygen Taskbar icon visible in the system tray." />
                        </StackPanel>
                        <ToggleSwitch x:Name="TraySwitch" Grid.Column="1" Header="On" Toggled="TraySwitch_Toggled" />
                    </Grid>
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="White" FontSize="18" Text="Start with Windows" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Automatically start Oxygen Taskbar when you sign in." />
                        </StackPanel>
                        <ToggleSwitch x:Name="StartupSwitch" Grid.Column="1" Header="On" Toggled="StartupSwitch_Toggled" />
                    </Grid>
                    <InfoBar x:Name="StartupPermissionInfo" IsOpen="True" Title="Startup registration" />
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="360" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="White" FontSize="18" Text="Dashboard hotkey" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Open or focus the Oxygen Taskbar dashboard." />
                        </StackPanel>
                        <TextBox x:Name="OpenHotkeyText" Grid.Column="1" PlaceholderText="Ctrl+Alt+G" />
                    </Grid>
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="360" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="White" FontSize="18" Text="Transparency toggle hotkey" />
                            <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Toggle taskbar translucency on or off." />
                        </StackPanel>
                        <TextBox x:Name="ToggleHotkeyText" Grid.Column="1" PlaceholderText="Ctrl+Alt+T" />
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="3" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <TextBlock Foreground="{StaticResource OxygenMutedTextBrush}" Text="Save applies the current tuning profile and app settings." VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{StaticResource GlassButtonStyle}" Click="Reset_Click" Content="Reset" />
                <Button Grid.Column="2" Style="{StaticResource GlassButtonStyle}" Background="{StaticResource OxygenBlueBrush}" Click="SaveChanges_Click" Content="Save changes" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
